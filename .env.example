# FujiFood Backend — Environment Variables
# Copy this to .env and fill in your values

# App
DEBUG=True
ENVIRONMENT=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fujifood
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Email (Mailtrap for dev)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@fujifood.com

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
